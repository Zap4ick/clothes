# LM Studio settings (must be running locally)

LOCAL_AI_BASE_URL=http://localhost:1234/v1
# LOCAL_AI_BASE_URLS=http://192.168.0.36:1234/v1,http://localhost:1234/v1
# LOCAL_AI_MODEL=google/gemma-4-e4b  # optional: pin a specific model, otherwise auto-detected
# AI_AVAILABILITY_TIMEOUT_MS=12000    # timeout for model availability checks (startup + ask)
# AI_RESPONSE_TIMEOUT_MS=45000        # timeout for full model responses
# AI_TIMEOUT_MS=45000                 # legacy fallback for both timeouts

## Option B: External endpoint (OpenAI, GitHub Models, etc.)
## Local endpoints are tried first; if they all fail and EXTERNAL_* vars are set, the app falls back to these
# EXTERNAL_AI_BASE_URL=https://models.inference.ai.azure.com  # or https://api.openai.com/v1
# Gemini (OpenAI-compatible): https://generativelanguage.googleapis.com/v1beta/openai
# EXTERNAL_AI_BASE_URLS=https://models1.example.com/v1,https://models2.example.com/v1
# EXTERNAL_AI_API_KEY=your_api_key_here
# EXTERNAL_AI_MODEL=gpt-4o # for Gemini, use model IDs like gemini-2.5-flash

## Wardrobe source (default: google-sheets)
# WARDROBE_SOURCE=local       # set to "local" to read from files instead
# WARDROBE_PATH=./wardrobe    # folder with your CSV/XLS files (default: ./wardrobe)

# Google Sheets
SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_PATH=./credentials/service-account.json
